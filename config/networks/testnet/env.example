# Copy to repo root as `.env.testnet`
# CHAINID must match config/networks/testnet/genesis.json

CHAINID=17172

# Phase A — first validator only (seed / “bootnode” for your testnet):
#   Leave BOOTNODE empty or use placeholder below, then:
#   ./scripts/start-validator.sh --network testnet --validator --max-nodes 1
# Phase B — set BOOTNODE to the enode from node 1 (./scripts/print-enode.sh --network testnet --node 1), then:
#   ./scripts/start-validator.sh --network testnet --validator --max-nodes 2
BOOTNODE=""
# BOOTNODE="enode://...@ip:32769"

# Public IP for --nat extip (optional; if empty, scripts use --nat any)
# IP=
